<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.qw.player.demo.widget.MusicView
        android:id="@+id/mMusicView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingTop="8dp"
        android:text="播放模式"
        android:textAppearance="?attr/textAppearanceOverline" />

    <RadioGroup
        android:id="@+id/mMusicPlayModeRG"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/mMusicPlayModeSingLoopRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="单曲循环" />

        <RadioButton
            android:id="@+id/mMusicPlayModeListLoopRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:checked="true"
            android:text="列表循环" />

        <RadioButton
            android:id="@+id/mMusicPlayModeRandomRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="随机" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:text="定时关闭"
        android:textAppearance="?attr/textAppearanceOverline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:paddingLeft="16dp">

        <Button
            android:id="@+id/mPlayCountdownBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:text="10秒" />

        <TextView
            android:id="@+id/mPlayCountdownInfoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未开启"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />
</LinearLayout>
