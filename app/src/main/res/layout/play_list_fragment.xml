<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.qw.player.demo.widget.MusicView
        android:id="@+id/mMusicView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingTop="8dp"
        android:text="播放模式"
        android:textAppearance="@style/TextAppearance.Overline" />

    <RadioGroup
        android:id="@+id/mMusicPlayModeRG"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/mMusicPlayModeSingLoopRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="单曲循环" />

        <RadioButton
            android:id="@+id/mMusicPlayModeListLoopRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:checked="true"
            android:text="列表循环" />

        <RadioButton
            android:id="@+id/mMusicPlayModeRandomRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="随机" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:text="定时关闭"
        android:textAppearance="@style/TextAppearance.Overline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:paddingLeft="16dp"
        android:layout_height="wrap_content">
        <Button
            android:id="@+id/mPlayCountdownBtn"
            android:layout_width="wrap_content"
            android:text="10秒"
            android:layout_marginRight="16dp"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/mPlayCountdownInfoLabel"
            android:text="未开启"
            android:textAppearance="@style/TextAppearance.Body2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <com.qw.widget.list.v2.PullRecyclerView
        android:id="@+id/mPullRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>