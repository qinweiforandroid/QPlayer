<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:duplicateParentState="true">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/mMusicCoverImg"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <TextView
        android:id="@+id/mMusicTitleLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginLeft="12dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:paddingRight="32dp"
        android:text="拯救歌荒"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@id/mMusicAuthorLabel"
        app:layout_constraintEnd_toStartOf="@+id/mMusicStateImg"
        app:layout_constraintStart_toEndOf="@+id/mMusicCoverImg"
        app:layout_constraintTop_toTopOf="@+id/mMusicCoverImg" />

    <TextView
        android:id="@+id/mMusicAuthorLabel"
        android:layout_width="182dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:text="周杰伦"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/mMusicTitleLabel"
        app:layout_constraintTop_toBottomOf="@+id/mMusicTitleLabel" />


    <ImageView
        android:id="@+id/mMusicStateImg"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginRight="16dp"
        android:src="@drawable/ic_baseline_pause_24"
        app:layout_constraintBottom_toBottomOf="@+id/mMusicCoverImg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/mMusicCoverImg" />
</androidx.constraintlayout.widget.ConstraintLayout>