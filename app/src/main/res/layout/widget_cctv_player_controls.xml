<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/mTopScrim"
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:background="@drawable/bg_player_top_scrim" />

    <View
        android:id="@+id/mBottomScrim"
        android:layout_width="match_parent"
        android:layout_height="144dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_bottom_scrim" />

    <LinearLayout
        android:id="@+id/mControlOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/mTopControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/mBackBtn"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_bili_control_button"
                android:contentDescription="@string/player_back"
                android:padding="9dp"
                android:src="@drawable/ic_player_back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mOverlayTitleLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="@string/player_title"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/mLiveBadgeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_bili_chip_dark"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:text="@string/player_live_badge"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/mClockLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/player_clock_placeholder"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom" />

        <LinearLayout
            android:id="@+id/mBottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/mPlayPauseBtn"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="8dp"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp">

                        <ImageView
                            android:id="@+id/mPlayPauseIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/player_pause"
                            android:src="@drawable/ic_player_pause" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <SeekBar
                            android:id="@+id/mSeekBar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="1000"
                            android:minHeight="18dp"
                            android:progressTint="@color/bili_pink"
                            android:thumbTint="@color/bili_pink" />

                        <TextView
                            android:id="@+id/mProgressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="10dp"
                            android:text="00:00/00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/mFullscreenBtn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:padding="2dp">

                        <ImageView
                            android:id="@+id/mFullscreenIcon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/player_fullscreen"
                            android:src="@drawable/ic_player_fullscreen" />
                    </FrameLayout>
                </LinearLayout>
            </FrameLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="2dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
